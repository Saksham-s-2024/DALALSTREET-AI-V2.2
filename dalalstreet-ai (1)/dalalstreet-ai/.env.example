# ============================================================
# DalalStreet AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# Market quotes use yfinance (no API key). NEVER commit .env!
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=your_secret_key_here

# ── Kite Connect (Zerodha) — optional ─────────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Legacy (unused by ML reports) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (PostgreSQL) ─────────────────────────────────────
# Use asyncpg driver in URL (required by SQLAlchemy async in this project):
#   DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# If PASSWORD has @ # % etc., URL-encode it (e.g. @ → %40).
# Create DB in psql: CREATE DATABASE dalalstreet;
# Create user: CREATE USER dalalstreet_user WITH PASSWORD 'your_postgres_password';
# Grant: GRANT ALL PRIVILEGES ON DATABASE dalalstreet TO dalalstreet_user;
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dalalstreet
POSTGRES_USER=dalalstreet_user
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql+asyncpg://dalalstreet_user:your_postgres_password@localhost:5432/dalalstreet

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth (login / saved reports) ─────────────────────────
# Strong random secret in production. Tables users + report_archives are created on startup.
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Report Cache TTL ──────────────────────────────────────────
REPORT_CACHE_TTL_SECONDS=300
